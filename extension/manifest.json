{
  "manifest_version": 3,
  "name": "AutoPost",
  "version": "1.0",
  "description": "AutoPost",
  "permissions": [
    "cookies",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://autopost-delta.vercel.app/*",
      "https://lilac-delta.vercel.app/*",
      "http://localhost/*",
      "http://127.0.0.1/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*",
      "https://auto-soz9.vercel.app/*",
      "https://auto-soz9.vercel.app/**"
    ]
  }
}